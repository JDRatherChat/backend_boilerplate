# Base (prod-safe) requirements.
#
# Notes:
# - This template standardises on Django 4.2 LTS.
# - Keep this file *lean*: only runtime deps for an API-first backend.

# ---- Core Django ----
Django>=4.2,<4.3

# ---- Environment variables ----
django-environ

# ---- Database (local dev & CI) ----
# psycopg v3 with bundled libpq; good for local dev as well.
psycopg[binary]

# ---- REST API ----
djangorestframework
djangorestframework-simplejwt
drf-spectacular

# ---- Logging & Observability ----
# Sentry is optional at runtime (only initialises when SENTRY_DSN is set).
sentry-sdk[django]
python-json-logger

# ---- CORS for local frontend during dev ----
django-cors-headers

# ---- Developer utilities (safe in prod, but optional per project) ----
django-extensions
