# Shared settings (applies to all ENV values)
# Copy this file to environments/base.env and adjust as needed.

# Core
DEBUG=0
SECRET_KEY=change-me-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1

# Django
TIME_ZONE=Africa/Johannesburg
DJANGO_SETTINGS_MODULE=  # optional; manage.py uses ENV instead

# API / Auth
ACCESS_TOKEN_LIFETIME_MINUTES=15
REFRESH_TOKEN_LIFETIME_DAYS=7

# Sentry (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.0
