# Production settings (example)
# Copy this file to environments/prod.env for local smoke-testing only.
# In real deployments, prefer injecting env vars via your runtime.
ENV=prod

DEBUG=0
ALLOWED_HOSTS=yourdomain.com

# Postgres (replace with real credentials/host)
DATABASE_URL=postgres://user:password@db-host:5432/backend_boilerplate

# Security / HTTPS
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=0
SECURE_HSTS_PRELOAD=0

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=prod
SENTRY_TRACES_SAMPLE_RATE=0.0
